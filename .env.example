# Email (Resend) — contact form + newsletter
RESEND_API_KEY=
# Newsletter segment (subscribers). RESEND_AUDIENCE_ID still works as a
# fallback — Resend migrated audiences to segments with the same IDs.
RESEND_NEWSLETTER_SEGMENT_ID=
RESEND_AUDIENCE_ID=
# Segment for people who submit the contact form
RESEND_CONTACT_SEGMENT_ID=
CONTACT_FROM_EMAIL=hello@bylunalabs.com
CONTACT_TO_EMAIL=hello@bylunalabs.com

# Sanity CMS — defaults are baked in; override only if the project changes
NEXT_PUBLIC_SANITY_PROJECT_ID=mugt2oz4
NEXT_PUBLIC_SANITY_DATASET=production

# Shared secret for the Sanity → /api/revalidate webhook
SANITY_REVALIDATE_SECRET=
