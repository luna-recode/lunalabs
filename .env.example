# Email (Resend) — contact form + newsletter
RESEND_API_KEY=
# Segment IDs — printed by `node --env-file=.env.local scripts/setup-resend.mjs`,
# which models all segments/templates/events/automations in Resend.
# Newsletter falls back to legacy RESEND_AUDIENCE_ID (audiences became
# segments with the same IDs when Resend migrated).
RESEND_NEWSLETTER_SEGMENT_ID=
RESEND_CONTACT_SEGMENT_ID=
RESEND_AUDIENCE_ID=
CONTACT_FROM_EMAIL=hello@bylunalabs.com
CONTACT_TO_EMAIL=hello@bylunalabs.com

# Sanity CMS — defaults are baked in; override only if the project changes
NEXT_PUBLIC_SANITY_PROJECT_ID=mugt2oz4
NEXT_PUBLIC_SANITY_DATASET=production

# Shared secret for the Sanity → /api/revalidate webhook
SANITY_REVALIDATE_SECRET=
